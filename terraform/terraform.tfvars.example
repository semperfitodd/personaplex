environment = "personaplex"
region      = "us-east-1"
domain      = "example.com"

tags = {
  Project     = "personaplex"
  Owner       = "your-name"
  Environment = "personaplex"
  ManagedBy   = "Terraform"
}

ecr_repos = {
  frontend        = "frontend"
  personaplex     = "personaplex"
  voice-generator = "voice-generator"
}

vpc_cidr                     = "10.0.0.0/16"
vpc_redundancy               = false
enable_flow_log              = true
flow_log_retention_days      = 7

eks_cluster_version                  = "1.35"
cluster_endpoint_private_access      = true
cluster_endpoint_public_access       = true
cluster_endpoint_public_access_cidrs = ["0.0.0.0/0"]

eks_node_instance_type = ["t3.large", "t3a.large"]
cpu_node_capacity_type = "SPOT"
cpu_node_min_size      = 1
cpu_node_max_size      = 5
cpu_node_desired_size  = 2

gpu_node_instance_type = ["g6.2xlarge"]
gpu_node_capacity_type = "ON_DEMAND"
gpu_node_min_size      = 0
gpu_node_max_size      = 3
gpu_node_desired_size  = 1

node_volume_size       = 100
node_volume_type       = "gp3"
node_volume_iops       = 3000
node_volume_throughput = 125

personaplex_service_accounts    = ["personaplex:personaplex-sa"]
voice_generator_service_accounts = ["personaplex:voice-generator-sa"]
